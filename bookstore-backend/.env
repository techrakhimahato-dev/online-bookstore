# Server Configuration
PORT=3000

# JWT Secret Key - Change this to a long random string in production!
JWT_SECRET=my_super_secret_key_change_this_in_production_123456

# JWT Token expiry (how long login stays valid)
JWT_EXPIRES_IN=7d

# Default Admin Credentials (used when database is first created)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@bookstore.com
